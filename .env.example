# Copy this file to .env and fill in the values before running `docker compose up`.
# .env is git-ignored (.gitignore already contains `.env`).

# Required: PostgreSQL password.
# Used by BOTH the `db` service (POSTGRES_PASSWORD) and the `api` service
# (substituted into ConnectionStrings__Postgres as Password=...).
POSTGRES_PASSWORD=changeme

# Required: JWT signing key used by Messenger.Api for HS256 token signing.
# ASPNETCORE_ENVIRONMENT=Development in docker-compose.yml disables the SEC-03
# startup length guard, so any non-empty value works for local development.
# In Production (not in scope for this phase) this MUST be >= 32 ASCII chars.
JWT_SIGNING_KEY=dev-signing-key-for-local-docker-compose
