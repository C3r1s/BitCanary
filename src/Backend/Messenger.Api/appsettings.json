{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=canary_avo;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "Messenger.Api",
    "Audience": "Messenger.Client",
    "SigningKey": "replace-with-a-long-random-development-key",
    "ExpirationMinutes": 120
  },
  "Storage": {
    "RootPath": "storage"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5500", "http://127.0.0.1:5500"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
