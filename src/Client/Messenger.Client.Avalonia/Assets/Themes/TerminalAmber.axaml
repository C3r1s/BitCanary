<!-- Терминальная цветовая тема BitCanary «TerminalAmber». -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  
  <x:Boolean x:Key="IsTerminalTheme">True</x:Boolean>

  
  
  <Color x:Key="TerminalBackgroundColor">#0A0800</Color>
  <Color x:Key="TerminalSurfaceColor">#111009</Color>
  <Color x:Key="TerminalTextColor">#FFB300</Color>
  <Color x:Key="TerminalAccentColor">#FF8C00</Color>

  <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#0A0800" />
  <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#111009" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush" Color="#FFB300" />
  <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#FF8C00" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush" Color="#FF8C00" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#7A5500" />

  
  <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#0A0800" />
  <SolidColorBrush x:Key="SystemControlAcrylicWindowBrush" Color="#0A0800" />

  
  <FontFamily x:Key="ContentControlThemeFontFamily">Consolas, JetBrains Mono, Courier New, monospace</FontFamily>
</ResourceDictionary>
