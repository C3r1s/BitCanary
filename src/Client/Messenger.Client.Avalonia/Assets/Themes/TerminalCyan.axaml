<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Sentinel key used by ThemeService to identify and remove terminal dictionaries -->
  <x:Boolean x:Key="IsTerminalTheme">True</x:Boolean>

  <!-- Cyberpunk cyan color scheme -->
  <!-- Background / surface colors -->
  <Color x:Key="TerminalBackgroundColor">#050510</Color>
  <Color x:Key="TerminalSurfaceColor">#0A0A1A</Color>
  <Color x:Key="TerminalTextColor">#7DF9FF</Color>
  <Color x:Key="TerminalAccentColor">#00BFFF</Color>

  <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#050510" />
  <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#0A0A1A" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush" Color="#7DF9FF" />
  <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#00BFFF" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush" Color="#00BFFF" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#005F7F" />

  <!-- Application background -->
  <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#050510" />
  <SolidColorBrush x:Key="SystemControlAcrylicWindowBrush" Color="#050510" />

  <!-- Monospace font -->
  <FontFamily x:Key="ContentControlThemeFontFamily">Consolas, JetBrains Mono, Courier New, monospace</FontFamily>
</ResourceDictionary>
