<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:Messenger.Client.Avalonia.Views"
        xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
        mc:Ignorable="d"
        x:Class="Messenger.Client.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1440"
        Height="900"
        MinWidth="900"
        MinHeight="640"
        Background="#0A0A0A"
        Title="BITCANARY">

  <Panel>

    <!-- ═══════════════════════════════════════════════════════════
         MIGRATION OVERLAY
    ═══════════════════════════════════════════════════════════════ -->
    <Grid IsVisible="{Binding IsMigrating}"
          Background="#C0000000"
          ZIndex="50">
      <Border CornerRadius="0" Padding="32" MaxWidth="420"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1">
        <StackPanel Spacing="16" HorizontalAlignment="Center">
          <TextBlock Text="migrating local database..."
                     FontSize="13" HorizontalAlignment="Center" Foreground="#C8C8C8" />
          <ProgressBar IsIndeterminate="True" Width="200" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════
         SAFETY NUMBER OVERLAY
    ═══════════════════════════════════════════════════════════════ -->
    <Grid IsVisible="{Binding IsShowingSafetyNumber}"
          Background="#CC000000"
          ZIndex="100"
          PointerPressed="SafetyNumberScrim_PointerPressed">
      <Border CornerRadius="0" Padding="28" MaxWidth="480"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1">
        <views:SafetyNumberView DataContext="{Binding SafetyNumber}" />
      </Border>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════
         SETTINGS OVERLAY
    ═══════════════════════════════════════════════════════════════ -->
    <Grid IsVisible="{Binding IsShowingSettings}"
          Background="#CC000000"
          ZIndex="100"
          PointerPressed="SettingsScrim_PointerPressed">
      <Border CornerRadius="0" Padding="28" MaxWidth="520"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1">
        <views:SettingsView DataContext="{Binding Settings}" />
      </Border>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════
         LOGIN SCREEN
    ═══════════════════════════════════════════════════════════════ -->
    <Grid IsVisible="{Binding !IsLoggedIn}" Background="#0A0A0A">
      <views:LoginView DataContext="{Binding LoginVm}" />
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════
         MAIN MESSENGER
    ═══════════════════════════════════════════════════════════════ -->
    <Grid RowDefinitions="Auto,Auto,*" IsVisible="{Binding IsLoggedIn}">

      <!-- Row 0: Flat status bar -->
      <Border Grid.Row="0"
              Background="#0D0D0D"
              BorderBrush="#1E1E1E"
              BorderThickness="0,0,0,1"
              Padding="16,9">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="12">
          <TextBlock Grid.Column="0"
                     Text="[ BITCANARY ]"
                     FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="{Binding StatusMessage}"
                     FontSize="12" Foreground="#484848"
                     VerticalAlignment="Center" />
          
          <!-- Connection status -->
          <TextBlock Grid.Column="2" Text="● ONLINE" FontSize="12" Foreground="#00CC66"
                     VerticalAlignment="Center" IsVisible="{Binding IsOnline}" />
          <TextBlock Grid.Column="2" Text="◌ RECONNECTING" FontSize="12" Foreground="#D9A020"
                     VerticalAlignment="Center" IsVisible="{Binding IsReconnecting}" />
          <TextBlock Grid.Column="2" Text="○ OFFLINE" FontSize="12" Foreground="#E05050"
                     VerticalAlignment="Center" IsVisible="{Binding IsOffline}" />

          <!-- Search -->
          <Button Grid.Column="3"
                  Content="[SEARCH]"
                  Command="{Binding ToggleGlobalSearchCommand}"
                  Background="Transparent" Padding="8,4"
                  ToolTip.Tip="Search messages (Ctrl+F)" />

          <Button Grid.Column="4"
                  Content="[ REFRESH ]"
                  Command="{Binding RefreshCommand}"
                  Background="Transparent" Padding="8,4"
                  ToolTip.Tip="Refresh" />

          <TextBlock Grid.Column="5"
                     Text="{Binding CurrentUsername}"
                     IsVisible="{Binding HasCurrentUsername}"
                     FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- Row 1: Offline banner -->
      <Border Grid.Row="1"
              Background="#191200"
              BorderBrush="#282000"
              BorderThickness="0,0,0,1"
              Padding="16,6"
              IsVisible="{Binding ShowOfflineBanner}">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="OFFLINE — showing cached messages"
                     Foreground="#D9A020" FontSize="12"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Content="[X]"
                  Command="{Binding DismissOfflineBannerCommand}"
                  Background="Transparent" Foreground="#D9A020"
                  Padding="8,4" ToolTip.Tip="Dismiss" />
        </Grid>
      </Border>

      <!-- Row 2: Two-column layout: sidebar | chat -->
      <Grid Grid.Row="2" ColumnDefinitions="262,*">

        <!-- Sidebar with right border acting as divider -->
        <Border Grid.Column="0"
                BorderBrush="#1E1E1E"
                BorderThickness="0,0,1,0">
          <views:ChatListView DataContext="{Binding ChatList}" />
        </Border>

        <!-- Right panel -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto">

          <!-- Empty state -->
          <Border Grid.Row="0" Background="Transparent" IsVisible="{Binding NoChatSelected}">
            <TextBlock Text="select a conversation to start messaging"
                       FontSize="12" Foreground="#333333"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>

          <!-- Chat window -->
          <Panel Grid.Row="0" IsVisible="{Binding !NoChatSelected}">
            <views:ChatWindowView DataContext="{Binding ChatWindow}" />
          </Panel>

          <!-- Message input with top border separator -->
          <Border Grid.Row="1"
                  IsVisible="{Binding !NoChatSelected}"
                  BorderBrush="#1E1E1E"
                  BorderThickness="0,1,0,0">
            <views:MessageInputView DataContext="{Binding MessageInput}" />
          </Border>
        </Grid>

      </Grid>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════
         FATAL ERROR OVERLAY  (STAB-01 — survives unhandled exceptions)
    ═══════════════════════════════════════════════════════════════ -->
    <Grid IsVisible="{Binding IsShowingDebugError}"
          Background="#CC000000"
          ZIndex="200">
      <Border MaxWidth="700" MaxHeight="520"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#0E0E0E" BorderBrush="#E05050" BorderThickness="1"
              Padding="0">
        <Grid RowDefinitions="Auto,*,Auto">

          <!-- Title bar -->
          <Border Grid.Row="0"
                  Background="#1A0505"
                  BorderBrush="#E05050" BorderThickness="0,0,0,1"
                  Padding="14,8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Something went wrong"
                         FontSize="13" FontWeight="Bold"
                         Foreground="#E05050"
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="[X]"
                      Command="{Binding CloseDebugErrorCommand}"
                      Background="Transparent"
                      Foreground="#E05050"
                      Padding="8,4" FontSize="12" />
            </Grid>
          </Border>

          <!-- Scrollable error detail -->
          <ScrollViewer Grid.Row="1" MaxHeight="420" Padding="14,10">
            <TextBlock Text="{Binding DebugErrorText}"
                       FontSize="11"
                       FontFamily="Consolas,Courier New,monospace"
                       Foreground="#C8C8C8"
                       TextWrapping="Wrap" />
          </ScrollViewer>

          <!-- Footer -->
          <Border Grid.Row="2"
                  Background="#0A0A0A"
                  BorderBrush="#2A2A2A" BorderThickness="0,1,0,0"
                  Padding="14,8">
            <Button Content="[ CLOSE ]"
                    Command="{Binding CloseDebugErrorCommand}"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    Foreground="#C8C8C8"
                    BorderBrush="#404040" BorderThickness="1"
                    Padding="10,4" FontSize="12" />
          </Border>

        </Grid>
      </Border>
    </Grid>

  </Panel>
</Window>
