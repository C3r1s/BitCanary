<!-- Главное окно BitCanary: тёмный терминальный UI, боковая панель чатов и область переписки. -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:Messenger.Client.Avalonia.Views"
        xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
        mc:Ignorable="d"
        x:Class="Messenger.Client.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1440"
        Height="900"
        MinWidth="900"
        MinHeight="640"
        Background="#0A0A0A"
        Title="BITCANARY">

  <Panel>

    
    <Grid IsVisible="{Binding IsMigrating}"
          Background="#C0000000"
          ZIndex="50">
      <Border CornerRadius="0" Padding="32" MaxWidth="420"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1">
        <StackPanel Spacing="16" HorizontalAlignment="Center">
          <TextBlock Text="migrating local database..."
                     FontSize="13" HorizontalAlignment="Center" Foreground="#C8C8C8" />
          <ProgressBar IsIndeterminate="True" Width="200" />
        </StackPanel>
      </Border>
    </Grid>

    
    <Grid IsVisible="{Binding IsShowingSafetyNumber}"
          Background="#CC000000"
          ZIndex="100"
          PointerPressed="SafetyNumberScrim_PointerPressed">
      <Border CornerRadius="0" Padding="28" MaxWidth="480"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1">
        <views:SafetyNumberView DataContext="{Binding SafetyNumber}" />
      </Border>
    </Grid>

    
    <Grid IsVisible="{Binding IsShowingSettings}"
          Background="#CC000000"
          ZIndex="100"
          PointerPressed="SettingsScrim_PointerPressed">
      <Border CornerRadius="0" Padding="28" MaxWidth="520"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1">
        <views:SettingsView DataContext="{Binding Settings}" />
      </Border>
    </Grid>

    
    <Grid IsVisible="{Binding IsConfirmingDeleteChat}"
          Background="#CC000000"
          ZIndex="110"
          PointerPressed="DeleteChatScrim_PointerPressed">
      <Border CornerRadius="0" Padding="20" MaxWidth="520"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1">
        <StackPanel Spacing="14">
          <TextBlock Text="Delete chat?"
                     FontSize="15"
                     FontWeight="Bold"
                     Foreground="#E05050" />
          <TextBlock Text="{Binding PendingDeleteChatTitle}"
                     FontSize="12"
                     Foreground="#C8C8C8"
                     TextWrapping="Wrap" />
          <TextBlock Text="This will remove the chat from UI and clear all local message history."
                     FontSize="11"
                     Foreground="#7A7A7A"
                     TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="[ CANCEL ]"
                    Command="{Binding CancelDeleteChatCommand}"
                    Background="Transparent"
                    Foreground="#C8C8C8"
                    BorderBrush="#404040"
                    BorderThickness="1"
                    Padding="10,4" />
            <Button Content="[ DELETE ]"
                    Command="{Binding ConfirmDeleteChatCommand}"
                    Background="#1A0505"
                    Foreground="#E05050"
                    BorderBrush="#E05050"
                    BorderThickness="1"
                    Padding="10,4" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    
    <Grid IsVisible="{Binding !IsLoggedIn}" Background="#0A0A0A">
      <views:LoginView DataContext="{Binding LoginVm}" />
    </Grid>

    
    <Grid RowDefinitions="Auto,Auto,*" IsVisible="{Binding IsLoggedIn}">

      
      <Border Grid.Row="0"
              Background="#0D0D0D"
              BorderBrush="#1E1E1E"
              BorderThickness="0,0,0,1"
              Padding="16,9">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="16">
          <TextBlock Grid.Column="0"
                     Text="[ BITCANARY ]"
                     FontSize="14" FontWeight="Bold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="{Binding StatusMessage}"
                     FontSize="14" Foreground="#484848"
                     VerticalAlignment="Center" />

          
          <TextBlock Grid.Column="2" Text="● ONLINE" FontSize="14" Foreground="#00CC66"
                     VerticalAlignment="Center" IsVisible="{Binding IsOnline}" />
          <TextBlock Grid.Column="2" Text="◌ RECONNECTING" FontSize="14" Foreground="#D9A020"
                     VerticalAlignment="Center" IsVisible="{Binding IsReconnecting}" />
          <TextBlock Grid.Column="2" Text="○ OFFLINE" FontSize="14" Foreground="#E05050"
                     VerticalAlignment="Center" IsVisible="{Binding IsOffline}" />

          <Button Grid.Column="3"
                  Content="[ REFRESH ]"
                  Command="{Binding RefreshCommand}"
                  Background="Transparent"
                  Padding="8,4"
                  FontSize="14"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Refresh" />

          <TextBlock Grid.Column="4"
                     Text="{Binding CurrentUsername}"
                     IsVisible="{Binding HasCurrentUsername}"
                     FontSize="14" FontWeight="Bold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      
      <Border Grid.Row="1"
              Background="#191200"
              BorderBrush="#282000"
              BorderThickness="0,0,0,1"
              Padding="16,6"
              IsVisible="{Binding ShowOfflineBanner}">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="OFFLINE — showing cached messages"
                     Foreground="#D9A020" FontSize="12"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Content="[X]"
                  Command="{Binding DismissOfflineBannerCommand}"
                  Background="Transparent" Foreground="#D9A020"
                  Padding="8,4" ToolTip.Tip="Dismiss" />
        </Grid>
      </Border>

      
      <Grid Grid.Row="2" ColumnDefinitions="262,*">

        
        <Border Grid.Column="0"
                BorderBrush="#1E1E1E"
                BorderThickness="0,0,1,0">
          <views:ChatListView DataContext="{Binding ChatList}" />
        </Border>

        
        <Grid Grid.Column="1" RowDefinitions="*,Auto">

          
          <Border Grid.Row="0" Background="Transparent" IsVisible="{Binding NoChatSelected}">
            <TextBlock Text="select a conversation to start messaging"
                       FontSize="12" Foreground="#333333"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>

          
          <Panel Grid.Row="0" IsVisible="{Binding !NoChatSelected}">
            <views:ChatWindowView DataContext="{Binding ChatWindow}" />
          </Panel>

          
          <Border Grid.Row="1"
                  IsVisible="{Binding !NoChatSelected}"
                  BorderBrush="#1E1E1E"
                  BorderThickness="0,1,0,0">
            <views:MessageInputView DataContext="{Binding MessageInput}" />
          </Border>
        </Grid>

      </Grid>
    </Grid>

    
    <Grid IsVisible="{Binding IsShowingDebugError}"
          Background="#CC000000"
          ZIndex="200">
      <Border MaxWidth="700" MaxHeight="520"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="#0E0E0E" BorderBrush="#E05050" BorderThickness="1"
              Padding="0">
        <Grid RowDefinitions="Auto,*,Auto">

          
          <Border Grid.Row="0"
                  Background="#1A0505"
                  BorderBrush="#E05050" BorderThickness="0,0,0,1"
                  Padding="14,8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Something went wrong"
                         FontSize="13" FontWeight="Bold"
                         Foreground="#E05050"
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="[X]"
                      Command="{Binding CloseDebugErrorCommand}"
                      Background="Transparent"
                      Foreground="#E05050"
                      Padding="8,4" FontSize="12" />
            </Grid>
          </Border>

          
          <ScrollViewer Grid.Row="1" MaxHeight="420" Padding="14,10">
            <TextBlock Text="{Binding DebugErrorText}"
                       FontSize="11"
                       FontFamily="Consolas,Courier New,monospace"
                       Foreground="#C8C8C8"
                       TextWrapping="Wrap" />
          </ScrollViewer>

          
          <Border Grid.Row="2"
                  Background="#0A0A0A"
                  BorderBrush="#2A2A2A" BorderThickness="0,1,0,0"
                  Padding="14,8">
            <Button Content="[ CLOSE ]"
                    Command="{Binding CloseDebugErrorCommand}"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    Foreground="#C8C8C8"
                    BorderBrush="#404040" BorderThickness="1"
                    Padding="10,4" FontSize="12" />
          </Border>

        </Grid>
      </Border>
    </Grid>

  </Panel>
</Window>
