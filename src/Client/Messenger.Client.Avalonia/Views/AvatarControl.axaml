<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Messenger.Client.Avalonia.Views"
             x:Class="Messenger.Client.Avalonia.Views.AvatarControl"
             x:DataType="views:AvatarControl"
             Width="28"
             Height="28">
  <Border x:Name="AvatarBorder"
          Width="28"
          Height="28"
          CornerRadius="0"
          BorderThickness="1">
    <TextBlock x:Name="InitialText"
               FontSize="11"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
  </Border>
</UserControl>
