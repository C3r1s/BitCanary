<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             xmlns:views="using:Messenger.Client.Avalonia.Views"
             x:Class="Messenger.Client.Avalonia.Views.ChatListView"
             x:DataType="vm:ChatListViewModel">
  <Border Classes="surface-card">
    <Grid RowDefinitions="Auto,*" RowSpacing="16">

      <!-- Header row: title + search toggle button -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
        <TextBlock Text="Chats"
                   FontSize="22"
                   FontWeight="SemiBold"
                   IsVisible="{Binding !IsSearchMode}"
                   VerticalAlignment="Center" />
        <TextBlock Text="Search"
                   FontSize="22"
                   FontWeight="SemiBold"
                   IsVisible="{Binding IsSearchMode}"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Content="&#128269;"
                Command="{Binding ToggleSearchCommand}"
                Background="Transparent"
                MinWidth="44"
                MinHeight="44"
                ToolTip.Tip="Search messages" />
      </Grid>

      <!-- Chat list mode (IsSearchMode = false) -->
      <Grid Grid.Row="1"
            RowDefinitions="Auto,*"
            RowSpacing="16"
            IsVisible="{Binding !IsSearchMode}">
        <TextBox Watermark="Search conversations"
                 Text="{Binding SearchText, Mode=TwoWay}" />

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Chats}"
                 SelectedItem="{Binding SelectedChat, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ChatListItemViewModel">
              <Grid ColumnDefinitions="*,Auto" Margin="0,8">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Subtitle}" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                  <TextBlock Text="{Binding LastActivity}" HorizontalAlignment="Right" />
                  <Border Background="#2C7A7B"
                          CornerRadius="999"
                          Padding="8,2">
                    <TextBlock Text="{Binding UnreadCount}" />
                  </Border>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <!-- Search results mode (IsSearchMode = true) -->
      <Panel Grid.Row="1" IsVisible="{Binding IsSearchMode}">
        <views:SearchResultsView DataContext="{Binding Search}" />
      </Panel>

    </Grid>
  </Border>
</UserControl>
