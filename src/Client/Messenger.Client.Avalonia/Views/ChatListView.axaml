<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             xmlns:views="using:Messenger.Client.Avalonia.Views"
             x:Class="Messenger.Client.Avalonia.Views.ChatListView"
             x:DataType="vm:ChatListViewModel">
  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0"
            Background="#0D0D0D"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="12,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="CHANNELS"
                   FontSize="12" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   IsVisible="{Binding !IsSearchMode}"
                   VerticalAlignment="Center" />
        <TextBlock Text="SEARCH"
                   FontSize="12" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   IsVisible="{Binding IsSearchMode}"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Content="[SEARCH]"
                Command="{Binding ToggleSearchCommand}"
                Background="Transparent"
                Padding="6,2"
                ToolTip.Tip="Search messages" />
      </Grid>
    </Border>

    <!-- Filter input (chat list mode only) -->
    <Border Grid.Row="1"
            IsVisible="{Binding !IsSearchMode}"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="10,6">
      <TextBox Watermark="filter conversations..."
               Text="{Binding SearchText, Mode=TwoWay}"
               Background="Transparent"
               BorderThickness="0"
               Padding="4,3"
               FontSize="12" />
    </Border>

    <!-- Chat list -->
    <ListBox Grid.Row="2"
             IsVisible="{Binding !IsSearchMode}"
             ItemsSource="{Binding Chats}"
             SelectedItem="{Binding SelectedChat, Mode=TwoWay}"
             Background="Transparent"
             BorderThickness="0"
             Padding="0">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:ChatListItemViewModel">
          <Border BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="12,9">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <!-- Name + preview -->
              <StackPanel Spacing="3" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           FontSize="13" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="11" Foreground="#505050"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <!-- Timestamp + unread badge -->
              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          Spacing="4"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding LastActivity}"
                           FontSize="11" Foreground="#404040"
                           HorizontalAlignment="Right" />
                <Border Background="#003D2A"
                        BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                        BorderThickness="1"
                        Padding="5,1"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding HasUnreadMessages}">
                  <TextBlock Text="{Binding UnreadCount}"
                             Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                             FontSize="11" />
                </Border>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Search results mode -->
    <Panel Grid.Row="2" IsVisible="{Binding IsSearchMode}">
      <views:SearchResultsView DataContext="{Binding Search}" />
    </Panel>

    <!-- Settings button pinned at bottom -->
    <Border Grid.Row="3"
            BorderBrush="#1E1E1E"
            BorderThickness="0,1,0,0">
      <Button Content="[ SETTINGS ]"
              MinHeight="36"
              Background="Transparent"
              Foreground="#505050"
              BorderThickness="0"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              FontSize="12"
              ToolTip.Tip="Settings"
              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSettingsCommand}" />
    </Border>

  </Grid>
</UserControl>
