<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             xmlns:views="using:Messenger.Client.Avalonia.Views"
             x:Class="Messenger.Client.Avalonia.Views.ChatListView"
             x:DataType="vm:ChatListViewModel">
  <Border Classes="surface-card">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">

      <!-- Header row: title + search toggle button -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
        <TextBlock Text="Chats"
                   FontSize="22"
                   FontWeight="SemiBold"
                   IsVisible="{Binding !IsSearchMode}"
                   VerticalAlignment="Center" />
        <TextBlock Text="Search"
                   FontSize="22"
                   FontWeight="SemiBold"
                   IsVisible="{Binding IsSearchMode}"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Content="&#128269;"
                Command="{Binding ToggleSearchCommand}"
                Background="Transparent"
                MinWidth="44"
                MinHeight="44"
                ToolTip.Tip="Search messages" />
      </Grid>

      <!-- Chat list mode (IsSearchMode = false) -->
      <Grid Grid.Row="1"
            RowDefinitions="Auto,*"
            RowSpacing="16"
            IsVisible="{Binding !IsSearchMode}">
        <TextBox Watermark="Search conversations"
                 Text="{Binding SearchText, Mode=TwoWay}" />

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Chats}"
                 SelectedItem="{Binding SelectedChat, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ChatListItemViewModel">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,6">
                <!-- Avatar -->
                <views:AvatarControl DisplayName="{Binding Title}" />

                <!-- Name + preview -->
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Subtitle}"
                             FontSize="13"
                             Opacity="0.72"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Timestamp + unread badge -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="4" VerticalAlignment="Center">
                  <TextBlock Text="{Binding LastActivity}"
                             FontSize="13"
                             Opacity="0.72"
                             HorizontalAlignment="Right" />
                  <Border Background="#2C7A7B"
                          CornerRadius="999"
                          Padding="8,4"
                          HorizontalAlignment="Right"
                          IsVisible="{Binding HasUnreadMessages}">
                    <TextBlock Text="{Binding UnreadCount}"
                               Foreground="White"
                               FontSize="12" />
                  </Border>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <!-- Search results mode (IsSearchMode = true) -->
      <Panel Grid.Row="1" IsVisible="{Binding IsSearchMode}">
        <views:SearchResultsView DataContext="{Binding Search}" />
      </Panel>

      <!-- Settings gear button pinned at bottom -->
      <Button Grid.Row="2"
              Content="&#9881; Settings"
              MinWidth="44"
              MinHeight="44"
              Background="Transparent"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              ToolTip.Tip="Settings"
              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSettingsCommand}" />

    </Grid>
  </Border>
</UserControl>
