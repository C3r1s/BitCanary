<!-- Разметка экрана BitCanary «ChatListView»: поля, списки и панели (Avalonia). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             xmlns:views="using:Messenger.Client.Avalonia.Views"
             x:Class="Messenger.Client.Avalonia.Views.ChatListView"
             x:DataType="vm:ChatListViewModel">
  <Grid RowDefinitions="Auto,Auto,*,Auto">

    
    <Border Grid.Row="0"
            Background="#0D0D0D"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="12,10">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
        <TextBlock Text="CHANNELS"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   IsVisible="{Binding IsInNormalMode}"
                   VerticalAlignment="Center" />
        <TextBlock Text="USER SEARCH"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   IsVisible="{Binding IsUserSearchMode}"
                   VerticalAlignment="Center" />
        <TextBlock Text="SEARCH"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   IsVisible="{Binding IsSearchMode}"
                   VerticalAlignment="Center" />
        <TextBlock Text="GROUP CREATION"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   IsVisible="{Binding IsGroupCreationMode}"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Content="[ G ]"
                Command="{Binding ToggleGroupCreationCommand}"
                Background="Transparent"
                Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                Padding="6,2"
                FontSize="14"
                ToolTip.Tip="Create a group" />
        <Button Grid.Column="2"
                Content="[ / ]"
                Command="{Binding ToggleSearchCommand}"
                Background="Transparent"
                Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                Padding="6,2"
                FontSize="14"
                ToolTip.Tip="Search messages" />
      </Grid>
    </Border>

    
    <Border Grid.Row="1"
            IsVisible="{Binding IsInNormalMode}"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="10,6">
      <TextBox Watermark="filter conversations..."
               Text="{Binding SearchText, Mode=TwoWay}"
               Background="Transparent"
               BorderThickness="0"
               Padding="4,3"
               FontSize="14" />
    </Border>

    
    <ListBox Grid.Row="2"
             IsVisible="{Binding IsInNormalMode}"
             ItemsSource="{Binding Chats}"
             SelectedItem="{Binding SelectedChat, Mode=TwoWay}"
             Background="Transparent"
             BorderThickness="0"
             Padding="0">
      <ListBox.Styles>
        
        <Style Selector="ListBoxItem TextBlock.chat-row-text">
          <Setter Property="Foreground" Value="#505050" />
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock.chat-row-text">
          <Setter Property="Foreground" Value="#000000" />
        </Style>
        
        <Style Selector="ListBoxItem TextBlock.chat-row-title">
          <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
        </Style>
      </ListBox.Styles>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:ChatListItemViewModel">
          <Border BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="12,9" Background="Transparent">
            <Border.ContextMenu>
              <ContextMenu Background="#111111"
                           BorderBrush="#1E1E1E"
                           BorderThickness="1"
                           CornerRadius="0"
                           MinWidth="160">
                <MenuItem Header="Delete chat"
                          Command="{Binding DeleteChatCommand}"
                          Foreground="#E05050"
                          FontSize="14"
                          Padding="8,8">
                  <MenuItem.Styles>
                    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
                      <Setter Property="Background" Value="#1A0505" />
                    </Style>
                  </MenuItem.Styles>
                </MenuItem>
                <Separator Background="#1E1E1E" />
                <MenuItem Header="Clear messages"
                          Command="{Binding ClearMessagesCommand}"
                          Foreground="#C8C8C8"
                          FontSize="14"
                          Padding="8,8">
                  <MenuItem.Styles>
                    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
                      <Setter Property="Background" Value="#1A1A1A" />
                    </Style>
                  </MenuItem.Styles>
                </MenuItem>
              </ContextMenu>
            </Border.ContextMenu>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              
              <StackPanel Spacing="3" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           FontSize="14" FontWeight="SemiBold"
                           Classes="chat-row-title" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="14"
                           Classes="chat-row-text"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
              
              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          Spacing="4"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding LastActivity}"
                           FontSize="14"
                           Classes="chat-row-text"
                           HorizontalAlignment="Right" />
                <Border Background="#003D2A"
                        BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                        BorderThickness="1"
                        Padding="5,1"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding HasUnreadMessages}">
                  <TextBlock Text="{Binding UnreadCount}"
                             Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                             FontSize="14" />
                </Border>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    
    <Panel Grid.Row="2" IsVisible="{Binding IsSearchMode}">
      <views:SearchResultsView DataContext="{Binding Search}" />
    </Panel>

    
    <Panel Grid.Row="2" IsVisible="{Binding IsUserSearchMode}">
      <views:UserSearchView DataContext="{Binding UserSearch}" />
    </Panel>

    
    <Panel Grid.Row="2" IsVisible="{Binding IsGroupCreationMode}">
      <views:GroupCreationView DataContext="{Binding GroupCreation}" />
    </Panel>

    
    <Border Grid.Row="3"
            BorderBrush="#1E1E1E"
            BorderThickness="0,1,0,0"
            Padding="10,8">
      <Button Content="[ SETTINGS ]"
              Height="36"
              MinHeight="36"
              Background="Transparent"
              Foreground="#505050"
              BorderThickness="0"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              FontSize="14"
              ToolTip.Tip="Settings"
              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSettingsCommand}" />
    </Border>

  </Grid>
</UserControl>
