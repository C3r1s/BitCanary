<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.ChatWindowView"
             x:DataType="vm:ChatWindowViewModel">
  <Border Classes="surface-card">
    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">

      <!-- Row 0: Find-bar (collapsible) -->
      <Border Grid.Row="0"
              IsVisible="{Binding IsFindBarVisible}"
              Background="#17384C"
              CornerRadius="8"
              Padding="8,4"
              Margin="0,0,0,4">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
          <TextBox Text="{Binding FindQuery, Mode=TwoWay}"
                   Watermark="Find in conversation..."
                   FontSize="16"
                   Name="FindQueryBox" />
          <TextBlock Grid.Column="1"
                     Text="{Binding FindMatchSummary}"
                     FontSize="13"
                     Opacity="0.7"
                     VerticalAlignment="Center" />
          <Button Grid.Column="2"
                  Content="X"
                  Command="{Binding CloseFindBarCommand}"
                  ToolTip.Tip="Close find bar"
                  Background="Transparent"
                  Padding="8,4" />
        </Grid>
      </Border>

      <!-- Row 1: Chat header (title, subtitle, safety number) -->
      <StackPanel Grid.Row="1" Spacing="4">
        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Subtitle}" Opacity="0.7" />

        <!-- Header action row: Safety Number button + verification badge -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">

          <!-- Safety Number pill button -->
          <Button Background="Transparent"
                  Padding="0"
                  Command="{Binding ShowSafetyNumberCommand}">
            <Border CornerRadius="999"
                    Padding="8,4"
                    BorderBrush="#2C7A7B"
                    BorderThickness="1">
              <TextBlock Text="Safety Number"
                         FontSize="13"
                         Foreground="#2C7A7B" />
            </Border>
          </Button>

          <!-- Unverified badge (shown when !IsSessionVerified) -->
          <Border CornerRadius="999"
                  Padding="8,4"
                  Background="#5C1A1A"
                  IsVisible="{Binding !IsSessionVerified}">
            <TextBlock Text="&#9888; Identity unverified"
                       FontSize="13"
                       Foreground="White" />
          </Border>

          <!-- Verified badge (shown when IsSessionVerified) -->
          <Border CornerRadius="999"
                  Padding="8,4"
                  Background="#2C7A7B"
                  IsVisible="{Binding IsSessionVerified}">
            <TextBlock Text="Verified"
                       FontSize="13"
                       Foreground="White" />
          </Border>

        </StackPanel>
      </StackPanel>

      <!-- Row 2: Typing status -->
      <TextBlock Grid.Row="2"
                 Text="{Binding TypingStatus}"
                 FontStyle="Italic"
                 Opacity="0.8" />

      <!-- Row 3: Messages area — empty state or scroll view -->
      <Panel Grid.Row="3">
        <!-- Empty state when no messages -->
        <TextBlock Text="No messages yet. Say hello!"
                   FontSize="16"
                   Opacity="0.4"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding HasNoMessages}" />

        <ScrollViewer Name="MessagesScroll" IsVisible="{Binding !HasNoMessages}">
          <ItemsControl ItemsSource="{Binding Messages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:MessageItemViewModel">
              <Panel>
                <!-- Normal message bubble (IsSystemBanner = false) -->
                <Border Classes="message-bubble"
                        Classes.outgoing="{Binding IsOutgoing}"
                        Classes.highlighted="{Binding IsHighlighted}"
                        IsVisible="{Binding !IsSystemBanner}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding SenderDisplayName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Timestamp}" Opacity="0.7" HorizontalAlignment="Right" />
                  </StackPanel>
                </Border>

                <!-- System banner (IsSystemBanner = true) -->
                <Border Background="#5C1A1A"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsSystemBanner}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="&#9888; Safety number changed"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{Binding BannerText}"
                               TextWrapping="Wrap"
                               FontSize="16"
                               Foreground="White" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Content="{Binding BannerAction1Label}"
                              Command="{Binding BannerAction1Command}"
                              Background="#2C7A7B"
                              Foreground="White"
                              FontSize="16"
                              FontWeight="SemiBold"
                              IsVisible="{Binding BannerAction1Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                      <Button Content="{Binding BannerAction2Label}"
                              Command="{Binding BannerAction2Command}"
                              Background="#5C1A1A"
                              Foreground="White"
                              FontSize="16"
                              IsVisible="{Binding BannerAction2Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </Panel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        </ScrollViewer>
      </Panel>
    </Grid>
  </Border>
</UserControl>
