<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             xmlns:views="using:Messenger.Client.Avalonia.Views"
             x:Class="Messenger.Client.Avalonia.Views.ChatWindowView"
             x:DataType="vm:ChatWindowViewModel">
  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,*">

    <!-- Row 0: Find bar (collapsible) -->
    <Border Grid.Row="0"
            IsVisible="{Binding IsFindBarVisible}"
            Background="#0C160C"
            BorderBrush="#1C3A1C"
            BorderThickness="0,0,0,1"
            Padding="12,6">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBox Text="{Binding FindQuery, Mode=TwoWay}"
                 Watermark="find in conversation..."
                 FontSize="13"
                 Background="Transparent"
                 BorderThickness="0"
                 Name="FindQueryBox" />
        <TextBlock Grid.Column="1"
                   Text="{Binding FindMatchSummary}"
                   FontSize="12" Foreground="#505050"
                   VerticalAlignment="Center" />
        <Button Grid.Column="2"
                Content="[X]"
                Command="{Binding CloseFindBarCommand}"
                Background="Transparent" Padding="6,4" />
      </Grid>
    </Border>

    <!-- Row 1: Chat header -->
    <Border Grid.Row="1"
            Background="#0D0D0D"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="14,10">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding Title}"
                     FontSize="14" FontWeight="Bold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
          <TextBlock Text="{Binding Subtitle}"
                     FontSize="11" Foreground="#505050" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">

          <!-- [ INFO ] button — group chats only -->
          <Button Content="[ INFO ]"
                  Command="{Binding ShowGroupInfoCommand}"
                  IsVisible="{Binding IsGroupChat}"
                  Background="Transparent"
                  Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                  Padding="6,3" FontSize="11" />

          <!-- Safety Number pill -->
          <Button Background="Transparent" Padding="0"
                  Command="{Binding ShowSafetyNumberCommand}">
            <Border Padding="7,3" BorderBrush="#2A2A2A" BorderThickness="1">
              <TextBlock Text="[safety#]" FontSize="11" Foreground="#505050" />
            </Border>
          </Button>

          <!-- Unverified badge — shown when chat contains plaintext messages (FEA-03) -->
          <Border Padding="7,3"
                  Background="#1C0808"
                  BorderBrush="#E05050"
                  BorderThickness="1"
                  IsVisible="{Binding IsUnverified}">
            <TextBlock Text="! UNVERIFIED" FontSize="11" Foreground="#E05050" />
          </Border>

          <!-- Verified badge -->
          <Border Padding="7,3"
                  Background="#003D2A"
                  BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                  BorderThickness="1"
                  IsVisible="{Binding IsSessionVerified}">
            <TextBlock Text="✓ VERIFIED"
                       FontSize="11"
                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
          </Border>

        </StackPanel>
      </Grid>
    </Border>

    <!-- Row 2: Typing status -->
    <Border Grid.Row="2"
            Padding="14,4"
            IsVisible="{Binding TypingStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding TypingStatus}"
                 FontSize="11" Foreground="#404040"
                 FontStyle="Italic" />
    </Border>

    <!-- Row 3: Messages -->
    <Panel Grid.Row="3">

      <!-- Empty state -->
      <TextBlock Text="no messages yet. say hello!"
                 FontSize="12" Foreground="#303030"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsVisible="{Binding HasNoMessages}" />

      <ScrollViewer Name="MessagesScroll"
                    IsVisible="{Binding !HasNoMessages}"
                    Padding="0,4,0,4">
        <ItemsControl ItemsSource="{Binding Messages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:MessageItemViewModel">
              <Panel>

                <!-- IRC-format message row -->
                <Border Classes="message-bubble"
                        Classes.outgoing="{Binding IsOutgoing}"
                        Classes.highlighted="{Binding IsHighlighted}"
                        IsVisible="{Binding !IsSystemBanner}"
                        Padding="14,2">
                  <Grid ColumnDefinitions="50,100,*,Auto" ColumnSpacing="6">

                    <!-- [HH:MM] timestamp -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Timestamp}"
                               FontSize="11" Foreground="#353535"
                               VerticalAlignment="Top" />

                    <!-- sender name (right-aligned, like IRC) -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding SenderDisplayName}"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                               Classes.sender-outgoing="{Binding IsOutgoing}"
                               TextTrimming="CharacterEllipsis"
                               TextAlignment="Right"
                               VerticalAlignment="Top" />

                    <!-- message text -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding DisplayText}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top" />

                    <!-- delivery status glyph + retry button -->
                    <StackPanel Grid.Column="3"
                                Orientation="Vertical"
                                Spacing="4"
                                IsVisible="{Binding IsOutgoing}"
                                VerticalAlignment="Top">
                      <!-- Normal status glyph (not failed) -->
                      <TextBlock Text="{Binding StatusGlyph}"
                                 FontSize="11"
                                 Foreground="#353535"
                                 IsVisible="{Binding !IsFailedOutgoing}" />
                      <!-- Failed status glyph (red ⚠) -->
                      <TextBlock Text="{Binding StatusGlyph}"
                                 FontSize="11"
                                 Foreground="#E05050"
                                 IsVisible="{Binding IsFailedOutgoing}" />
                      <!-- Retry button — visible only on outgoing failed messages -->
                      <Button Content="Retry"
                              FontSize="11"
                              Foreground="#E05050"
                              Background="Transparent"
                              BorderBrush="#E05050"
                              BorderThickness="1"
                              Padding="8,4"
                              MinWidth="44"
                              MinHeight="20"
                              VerticalAlignment="Top"
                              IsVisible="{Binding IsFailedOutgoing}"
                              Command="{Binding RetryCommand}" />
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- System banner -->
                <Border Background="#1C0808"
                        BorderBrush="#E05050"
                        BorderThickness="1"
                        Padding="14,10"
                        Margin="14,4"
                        IsVisible="{Binding IsSystemBanner}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="! SAFETY NUMBER CHANGED"
                               FontSize="12" FontWeight="Bold"
                               Foreground="#E05050" />
                    <TextBlock Text="{Binding BannerText}"
                               TextWrapping="Wrap"
                               FontSize="12" Foreground="#C87070" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Content="{Binding BannerAction1Label}"
                              Command="{Binding BannerAction1Command}"
                              Background="#003D2A"
                              Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                              BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                              BorderThickness="1" FontSize="12"
                              IsVisible="{Binding BannerAction1Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                      <Button Content="{Binding BannerAction2Label}"
                              Command="{Binding BannerAction2Command}"
                              Background="#1A0000"
                              Foreground="#E05050"
                              BorderBrush="#E05050"
                              BorderThickness="1" FontSize="12"
                              IsVisible="{Binding BannerAction2Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </StackPanel>
                </Border>

              </Panel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Panel>

    <!-- Column 1: Group info panel (right side, all rows) -->
    <Border Grid.Column="1"
            Grid.RowSpan="4"
            IsVisible="{Binding IsGroupInfoVisible}"
            Width="240"
            BorderBrush="#1E1E1E"
            BorderThickness="1,0,0,0">
      <views:GroupInfoView DataContext="{Binding GroupInfo}" />
    </Border>

  </Grid>
</UserControl>
