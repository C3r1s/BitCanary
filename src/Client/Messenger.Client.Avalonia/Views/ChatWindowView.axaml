<!-- Разметка экрана BitCanary «ChatWindowView»: поля, списки и панели (Avalonia). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             xmlns:views="using:Messenger.Client.Avalonia.Views"
             x:Class="Messenger.Client.Avalonia.Views.ChatWindowView"
             x:DataType="vm:ChatWindowViewModel">
  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,*">

    
    <Border Grid.Row="0"
            IsVisible="{Binding IsFindBarVisible}"
            Background="#0C160C"
            BorderBrush="#1C3A1C"
            BorderThickness="0,0,0,1"
            Padding="12,6">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBox Text="{Binding FindQuery, Mode=TwoWay}"
                 Watermark="find in conversation..."
                 FontSize="13"
                 Background="Transparent"
                 BorderThickness="0"
                 Name="FindQueryBox" />
        <TextBlock Grid.Column="1"
                   Text="{Binding FindMatchSummary}"
                   FontSize="12" Foreground="#505050"
                   VerticalAlignment="Center" />
        <Button Grid.Column="2"
                Content="[X]"
                Command="{Binding CloseFindBarCommand}"
                Background="Transparent" Padding="6,4" />
      </Grid>
    </Border>

    
    <Border Grid.Row="1"
            Background="#0D0D0D"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="14,10">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Spacing="3">
          <TextBlock Text="{Binding Title}"
                     FontSize="14" FontWeight="Bold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
          <TextBlock Text="{Binding Subtitle}"
                     FontSize="14" Foreground="#505050" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">

          
          <Button Content="[ INFO ]"
                  Command="{Binding ShowGroupInfoCommand}"
                  IsVisible="{Binding IsGroupChat}"
                  Background="Transparent"
                  Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                  Padding="8,0"
                  Height="28"
                  MinHeight="28"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  FontSize="14" />

          
          <Button Background="Transparent"
                  Padding="0"
                  MinWidth="0"
                  MinHeight="28"
                  Height="28"
                  BorderThickness="0"
                  CornerRadius="0"
                  VerticalAlignment="Center"
                  IsVisible="{Binding IsDirectChat}"
                  Command="{Binding ShowSafetyNumberCommand}">
            <Border Height="28"
                    Padding="8,0"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1">
              <TextBlock Text="[safety#]"
                         FontSize="14"
                         Foreground="#505050"
                         VerticalAlignment="Center" />
            </Border>
          </Button>

          
          <Border Height="28"
                  Padding="8,0"
                  Background="#1C0808"
                  BorderBrush="#E05050"
                  BorderThickness="1"
                  VerticalAlignment="Center"
                  IsVisible="{Binding ShowUnverifiedBadge}">
            <TextBlock Text="! UNVERIFIED"
                       FontSize="14"
                       Foreground="#E05050"
                       VerticalAlignment="Center" />
          </Border>

          
          <Border Height="28"
                  Padding="8,0"
                  Background="#003D2A"
                  BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                  BorderThickness="1"
                  VerticalAlignment="Center"
                  IsVisible="{Binding ShowVerifiedBadge}">
            <TextBlock Text="✓ VERIFIED"
                       FontSize="14"
                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                       VerticalAlignment="Center" />
          </Border>

        </StackPanel>
      </Grid>
    </Border>

    
    <Border Grid.Row="2"
            Padding="14,4"
            IsVisible="{Binding TypingStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding TypingStatus}"
                 FontSize="14" Foreground="#404040"
                 FontStyle="Italic" />
    </Border>

    
    <Panel Grid.Row="3">

      
      <TextBlock Text="no messages yet. say hello!"
                 FontSize="14" Foreground="#303030"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsVisible="{Binding HasNoMessages}" />

      <ScrollViewer Name="MessagesScroll"
                    IsVisible="{Binding !HasNoMessages}"
                    Padding="0,4,0,4">
        <ItemsControl Name="MessagesItems"
                      ItemsSource="{Binding Messages}"
                      Margin="0,0,0,30">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:MessageItemViewModel">
              <Panel>

                
                <Border Classes="message-bubble"
                        Classes.outgoing="{Binding IsOutgoing}"
                        Classes.highlighted="{Binding IsHighlighted}"
                        IsVisible="{Binding !IsSystemBanner}"
                        Padding="14,2">
                  <Grid ColumnDefinitions="62,120,*,Auto" ColumnSpacing="6">

                    
                    <TextBlock Grid.Column="0"
                               Text="{Binding Timestamp}"
                               FontSize="14" Foreground="#353535"
                               VerticalAlignment="Top" />

                    
                    <TextBlock Grid.Column="1"
                               Text="{Binding SenderDisplayName}"
                               FontSize="14"
                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                               Classes.sender-outgoing="{Binding IsOutgoing}"
                               TextTrimming="CharacterEllipsis"
                               TextAlignment="Right"
                               VerticalAlignment="Top" />

                    
                    <StackPanel Grid.Column="2"
                                Orientation="Vertical"
                                Spacing="6"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left">
                      <Image Source="{Binding InlineImage}"
                             MaxWidth="320"
                             MaxHeight="260"
                             Stretch="Uniform"
                             IsVisible="{Binding HasInlineImage}" />
                      <StackPanel Orientation="Horizontal"
                                  Spacing="6"
                                  VerticalAlignment="Top"
                                  IsVisible="{Binding ShowTextGlyphRow}">
                        <TextBlock Text="{Binding DisplayText}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top"
                                   IsVisible="{Binding CaptionVisible}" />
                        <TextBlock Text="{Binding EncryptionGlyph}"
                                   FontSize="14"
                                   Foreground="#606060"
                                   VerticalAlignment="Top"
                                   IsVisible="{Binding ShowEncryptionGlyph}" />
                      </StackPanel>
                    </StackPanel>

                    
                    <StackPanel Grid.Column="3"
                                Orientation="Vertical"
                                Spacing="4"
                                IsVisible="{Binding IsOutgoing}"
                                VerticalAlignment="Top">
                      
                      <TextBlock Text="{Binding StatusGlyph}"
                                 FontSize="14"
                                 Foreground="#353535"
                                 IsVisible="{Binding !IsFailedOutgoing}" />
                      
                      <TextBlock Text="{Binding StatusGlyph}"
                                 FontSize="14"
                                 Foreground="#E05050"
                                 IsVisible="{Binding IsFailedOutgoing}" />
                      
                      <Button Content="Retry"
                              FontSize="14"
                              Foreground="#E05050"
                              Background="Transparent"
                              BorderBrush="#E05050"
                              BorderThickness="1"
                              Padding="8,4"
                              MinWidth="44"
                              MinHeight="20"
                              VerticalAlignment="Top"
                              IsVisible="{Binding ShowRetryButton}"
                              Command="{Binding RetryCommand}" />
                    </StackPanel>
                  </Grid>
                </Border>

                
                <Border Background="#1C0808"
                        BorderBrush="#E05050"
                        BorderThickness="1"
                        Padding="14,10"
                        Margin="14,4"
                        IsVisible="{Binding IsSystemBanner}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="! SAFETY NUMBER CHANGED"
                               FontSize="12" FontWeight="Bold"
                               Foreground="#E05050" />
                    <TextBlock Text="{Binding BannerText}"
                               TextWrapping="Wrap"
                               FontSize="12" Foreground="#C87070" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Content="{Binding BannerAction1Label}"
                              Command="{Binding BannerAction1Command}"
                              Background="#003D2A"
                              Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                              BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                              BorderThickness="1" FontSize="12"
                              IsVisible="{Binding BannerAction1Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                      <Button Content="{Binding BannerAction2Label}"
                              Command="{Binding BannerAction2Command}"
                              Background="#1A0000"
                              Foreground="#E05050"
                              BorderBrush="#E05050"
                              BorderThickness="1" FontSize="12"
                              IsVisible="{Binding BannerAction2Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </StackPanel>
                </Border>

              </Panel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Panel>

    
    <Border Grid.Column="1"
            Grid.RowSpan="4"
            IsVisible="{Binding IsGroupInfoVisible}"
            Width="240"
            BorderBrush="#1E1E1E"
            BorderThickness="1,0,0,0">
      <views:GroupInfoView DataContext="{Binding GroupInfo}" />
    </Border>

  </Grid>
</UserControl>
