<!-- Разметка экрана BitCanary «GroupCreationView»: поля, списки и панели (Avalonia). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.GroupCreationView"
             x:DataType="vm:GroupCreationViewModel">

  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

    
    <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="4" Padding="12,8" Margin="0,0,0,4">
      <TextBox x:Name="GroupNameInput"
               Text="{Binding GroupName, Mode=TwoWay}"
               Watermark="group name..."
               Background="Transparent"
               BorderThickness="0"
               FontSize="14" />
    </Border>

    
    <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="4" Padding="12,8" Margin="0,0,0,4">
      <TextBox Text="{Binding Description, Mode=TwoWay}"
               Watermark="description (optional)"
               Background="Transparent"
               BorderThickness="0"
               FontSize="14" />
    </Border>

    
    <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="4" Padding="12,8" Margin="0,0,0,4">
      <TextBox x:Name="MemberSearchInput"
               Text="{Binding MemberSearchQuery, Mode=TwoWay}"
               Watermark="search members..."
               Background="Transparent"
               BorderThickness="0"
               FontSize="14" />
    </Border>

    
    <ItemsControl Grid.Row="3"
                  ItemsSource="{Binding SelectedMembers}"
                  Margin="0,0,0,4">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:UserResultItemViewModel">
          <Border Background="#003D2A"
                  BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2"
                  Margin="2">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding Username}"
                         FontSize="14"
                         Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
              <Button Content="[x]"
                      FontSize="14"
                      Background="Transparent"
                      Padding="2,0"
                      BorderThickness="0"
                      Foreground="#888888"
                      Command="{Binding $parent[UserControl].((vm:GroupCreationViewModel)DataContext).RemoveMemberCommand}"
                      CommandParameter="{Binding}" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    
    <Panel Grid.Row="4">
      <ListBox x:Name="MemberSearchResults"
               ItemsSource="{Binding SearchResults}"
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:UserResultItemViewModel">
            <Border Padding="12,8" BorderBrush="#141414" BorderThickness="0,0,0,1">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding DisplayName}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                <TextBlock Text="{Binding Username}"
                           FontSize="14" Foreground="#888888" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border IsVisible="{Binding HasError}"
              Background="#1C1000"
              BorderBrush="#E08800"
              BorderThickness="1"
              CornerRadius="4"
              Padding="12,8"
              Margin="0,4"
              VerticalAlignment="Top">
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#E08800"
                   FontSize="14"
                   TextWrapping="Wrap" />
      </Border>
    </Panel>

    
    <Button Grid.Row="5"
            Content="[ CREATE GROUP ]"
            Command="{Binding CreateGroupCommand}"
            IsEnabled="{Binding CanCreate}"
            Background="#003D2A"
            Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
            BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
            BorderThickness="1"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            FontSize="14"
            Margin="0,4,0,0"
            Padding="8,6" />

  </Grid>
</UserControl>
