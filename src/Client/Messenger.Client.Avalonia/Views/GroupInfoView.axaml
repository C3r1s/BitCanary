<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.GroupInfoView"
             x:DataType="vm:GroupInfoViewModel"
             Background="#0A0A0A">

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

    <!-- Row 0: Group name header -->
    <Border Grid.Row="0"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="12,10">
      <StackPanel Spacing="4">
        <!-- Display mode -->
        <TextBlock Text="{Binding GroupName}"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   IsVisible="{Binding !IsEditing}"
                   TextTrimming="CharacterEllipsis" />
        <!-- Edit mode -->
        <TextBox x:Name="GroupNameEdit"
                 Text="{Binding GroupName, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0,0,0,1"
                 BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                 FontSize="14" FontWeight="Bold"
                 IsVisible="{Binding IsEditing}"
                 Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />

        <!-- Description display -->
        <TextBlock Text="{Binding Description}"
                   FontSize="11" Foreground="#505050"
                   IsVisible="{Binding !IsEditing}"
                   TextWrapping="Wrap" />
        <!-- Description edit -->
        <TextBox Text="{Binding Description, Mode=TwoWay}"
                 Watermark="description..."
                 Background="Transparent"
                 BorderThickness="0,0,0,1"
                 BorderBrush="#505050"
                 FontSize="11"
                 IsVisible="{Binding IsEditing}"
                 Foreground="#888888" />
      </StackPanel>
    </Border>

    <!-- Row 1: Edit / Save / Cancel buttons -->
    <Border Grid.Row="1" Padding="8,6" BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Content="[ EDIT ]"
                Command="{Binding EditCommand}"
                IsVisible="{Binding !IsEditing}"
                Background="Transparent"
                Foreground="#888888"
                Padding="6,2" FontSize="11" />
        <Button Content="[ SAVE ]"
                Command="{Binding SaveCommand}"
                IsVisible="{Binding IsEditing}"
                Background="#003D2A"
                Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                BorderThickness="1"
                Padding="6,2" FontSize="11" />
        <Button Content="[ CANCEL ]"
                Command="{Binding CancelEditCommand}"
                IsVisible="{Binding IsEditing}"
                Background="Transparent"
                Foreground="#E05050"
                Padding="6,2" FontSize="11" />
      </StackPanel>
    </Border>

    <!-- Row 2: Members section header -->
    <Border Grid.Row="2" Padding="12,8" BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
      <TextBlock FontSize="11" FontWeight="Bold" Foreground="#505050">
        <Run Text="MEMBERS (" /><Run Text="{Binding MemberCount}" /><Run Text=")" />
      </TextBlock>
    </Border>

    <!-- Row 3: Member list -->
    <ScrollViewer Grid.Row="3">
      <ListBox ItemsSource="{Binding Members}"
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:GroupMemberItemViewModel">
            <Border Padding="10,8" BorderBrush="#141414" BorderThickness="0,0,0,1">
              <StackPanel Spacing="4">
                <!-- Role badge + display name row -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding RoleBadge}"
                             FontSize="10" FontWeight="Bold"
                             Foreground="#505050" />
                  <TextBlock Text="{Binding DisplayName}"
                             FontSize="12"
                             Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                </StackPanel>
                <!-- Action buttons row -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Content="[ REMOVE ]"
                          IsVisible="{Binding CanRemove}"
                          Command="{Binding RemoveCommand}"
                          Background="Transparent"
                          Foreground="#E05050"
                          Padding="4,2" FontSize="10" />
                  <Button Content="[ MAKE ADMIN ]"
                          IsVisible="{Binding CanMakeAdmin}"
                          Command="{Binding MakeAdminCommand}"
                          Background="Transparent"
                          Foreground="#888888"
                          Padding="4,2" FontSize="10" />
                  <Button Content="[ REVOKE ADMIN ]"
                          IsVisible="{Binding CanRevokeAdmin}"
                          Command="{Binding RevokeAdminCommand}"
                          Background="Transparent"
                          Foreground="#888888"
                          Padding="4,2" FontSize="10" />
                  <Button Content="[ LEAVE GROUP ]"
                          IsVisible="{Binding CanLeave}"
                          Command="{Binding LeaveCommand}"
                          Background="Transparent"
                          Foreground="#E05050"
                          Padding="4,2" FontSize="10" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>

    <!-- Row 4: Error + Close -->
    <Border Grid.Row="4" Padding="8,6">
    <StackPanel Spacing="4">
      <Border IsVisible="{Binding HasError}"
              Background="#1C1000"
              BorderBrush="#E08800"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10,6">
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#E08800"
                   FontSize="11"
                   TextWrapping="Wrap" />
      </Border>
      <Button Content="[ CLOSE ]"
              Command="{Binding CloseCommand}"
              Background="Transparent"
              Foreground="#505050"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Padding="6,4" FontSize="11" />
    </StackPanel>
    </Border>

  </Grid>
</UserControl>
