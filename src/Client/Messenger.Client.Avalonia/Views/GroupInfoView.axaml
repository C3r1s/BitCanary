<!-- Разметка экрана BitCanary «GroupInfoView»: поля, списки и панели (Avalonia). -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.GroupInfoView"
             x:DataType="vm:GroupInfoViewModel"
             Background="#0A0A0A">

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

    
    <Border Grid.Row="0"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="12,10">
      <StackPanel Spacing="4">
        
        <TextBlock Text="{Binding GroupName}"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   IsVisible="{Binding !IsEditing}"
                   TextTrimming="CharacterEllipsis" />
        
        <TextBox x:Name="GroupNameEdit"
                 Text="{Binding GroupName, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0,0,0,1"
                 BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                 FontSize="14" FontWeight="Bold"
                 HorizontalContentAlignment="Center"
                 IsVisible="{Binding IsEditing}"
                 Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />

        
        <TextBlock Text="{Binding Description}"
                   FontSize="14" Foreground="#505050"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   IsVisible="{Binding !IsEditing}"
                   TextWrapping="Wrap" />
        
        <TextBox Text="{Binding Description, Mode=TwoWay}"
                 Watermark="description..."
                 Background="Transparent"
                 BorderThickness="0,0,0,1"
                 BorderBrush="#505050"
                 FontSize="14"
                 IsVisible="{Binding IsEditing}"
                 Foreground="#888888" />
      </StackPanel>
    </Border>

    
    <Border Grid.Row="1" Padding="8,6" BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Content="[ EDIT ]"
                Command="{Binding EditCommand}"
                IsVisible="{Binding CanShowEditButton}"
                Background="Transparent"
                Foreground="#888888"
                Padding="6,2" FontSize="14" />
        <Button Content="[ LEAVE GROUP ]"
                Command="{Binding LeaveGroupCommand}"
                IsVisible="{Binding CanShowLeaveButton}"
                Background="Transparent"
                Foreground="#E05050"
                Padding="6,2" FontSize="14" />
        <Button Content="[ SAVE ]"
                Command="{Binding SaveCommand}"
                IsVisible="{Binding IsEditing}"
                Background="#003D2A"
                Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                BorderThickness="1"
                Padding="6,2" FontSize="14" />
        <Button Content="[ CANCEL ]"
                Command="{Binding CancelEditCommand}"
                IsVisible="{Binding IsEditing}"
                Background="Transparent"
                Foreground="#E05050"
                Padding="6,2" FontSize="14" />
      </StackPanel>
    </Border>

    
    <Border Grid.Row="2" Padding="12,8" BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
      <StackPanel Spacing="8">
        <TextBlock FontSize="14" FontWeight="Bold" Foreground="#505050">
          <Run Text="MEMBERS (" /><Run Text="{Binding MemberCount}" /><Run Text=")" />
        </TextBlock>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsVisible="{Binding IsAdmin}">
          <TextBox Grid.Column="0"
                   Text="{Binding InviteUsername, Mode=TwoWay}"
                   Watermark="username to add..."
                   Background="Transparent"
                   BorderThickness="0,0,0,1"
                   BorderBrush="#505050"
                   FontSize="14"
                   Foreground="#C8C8C8" />
          <Button Grid.Column="1"
                  Content="[ ADD ]"
                  Command="{Binding AddMemberCommand}"
                  Background="#003D2A"
                  Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                  BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                  BorderThickness="1"
                  Padding="8,4"
                  FontSize="14" />
        </Grid>
      </StackPanel>
    </Border>

    
    <ScrollViewer Grid.Row="3">
      <ListBox ItemsSource="{Binding Members}"
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:GroupMemberItemViewModel">
            <Border Padding="10,8" BorderBrush="#141414" BorderThickness="0,0,0,1">
              <StackPanel Spacing="4">
                
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding RoleBadge}"
                             FontSize="14" FontWeight="Bold"
                             Foreground="#505050" />
                  <TextBlock Text="{Binding DisplayName}"
                             FontSize="14"
                             Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Content="[ REMOVE ]"
                          IsVisible="{Binding CanRemove}"
                          Command="{Binding RemoveCommand}"
                          Background="Transparent"
                          Foreground="#E05050"
                          Padding="4,2" FontSize="14" />
                  <Button Content="[ MAKE ADMIN ]"
                          IsVisible="{Binding CanMakeAdmin}"
                          Command="{Binding MakeAdminCommand}"
                          Background="Transparent"
                          Foreground="#888888"
                          Padding="4,2" FontSize="14" />
                  <Button Content="[ REVOKE ADMIN ]"
                          IsVisible="{Binding CanRevokeAdmin}"
                          Command="{Binding RevokeAdminCommand}"
                          Background="Transparent"
                          Foreground="#888888"
                          Padding="4,2" FontSize="14" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>

    
    <Border Grid.Row="4" Padding="8,6">
    <StackPanel Spacing="4">
      <Border IsVisible="{Binding HasError}"
              Background="#1C1000"
              BorderBrush="#E08800"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10,6">
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#E08800"
                   FontSize="14"
                   TextWrapping="Wrap" />
      </Border>
      <Button Content="[ CLOSE ]"
              Command="{Binding CloseCommand}"
              Background="Transparent"
              Foreground="#505050"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Padding="6,4" FontSize="14" />
    </StackPanel>
    </Border>

  </Grid>
</UserControl>
