<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.SafetyNumberView"
             x:DataType="vm:SafetyNumberViewModel">
  <StackPanel Spacing="16">

    <!-- Title + close -->
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="SAFETY NUMBER"
                 FontSize="13" FontWeight="Bold"
                 Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                 VerticalAlignment="Center" />
      <Button Grid.Column="1"
              Content="[X]"
              Command="{Binding CloseCommand}"
              Background="Transparent" Padding="8,4"
              VerticalAlignment="Center" />
    </Grid>

    <!-- Peer name -->
    <TextBlock Text="{Binding PeerDisplayName}"
               FontSize="13" Foreground="#888888" />

    <!-- Loading -->
    <ProgressBar IsIndeterminate="True" Width="200" IsVisible="{Binding IsLoading}" />

    <!-- Safety number digits -->
    <TextBlock Text="{Binding SafetyNumber}"
               FontSize="18" FontWeight="Bold"
               FontFamily="Cascadia Mono, Consolas, Courier New"
               Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
               TextWrapping="Wrap"
               TextAlignment="Center"
               IsVisible="{Binding !IsLoading}" />

    <!-- Instructions -->
    <Border BorderBrush="#1E1E1E" BorderThickness="0,1,0,0" Padding="0,12,0,0">
      <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="#888888">
        <Run Text="compare these numbers with " />
        <Run Text="{Binding PeerDisplayName}" FontWeight="Bold" Foreground="#C8C8C8" />
        <Run Text=" over a call or in person. if they match, this conversation is secure." />
      </TextBlock>
    </Border>

    <!-- Verified timestamp -->
    <StackPanel IsVisible="{Binding IsVerified}">
      <TextBlock Text="{Binding VerifiedOnText}"
                 Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                 FontSize="12" />
    </StackPanel>

    <!-- Verify button -->
    <Button Content="{Binding VerifyButtonText}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Background="#003D2A"
            Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
            BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
            BorderThickness="1"
            FontSize="13"
            Command="{Binding MarkAsVerifiedCommand}"
            IsEnabled="{Binding !IsVerified}" />

  </StackPanel>
</UserControl>
