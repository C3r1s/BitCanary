<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.SearchResultsView"
             x:DataType="vm:SearchViewModel">
  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <Border Grid.Row="0"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="12,8">
      <TextBlock Text="SEARCH"
                 FontSize="12" FontWeight="Bold"
                 Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
    </Border>

    <!-- Search input -->
    <Border Grid.Row="1"
            BorderBrush="#1E1E1E"
            BorderThickness="0,0,0,1"
            Padding="10,6">
      <TextBox Watermark="search all conversations..."
               Text="{Binding SearchQuery, Mode=TwoWay}"
               Background="Transparent"
               BorderThickness="0"
               FontSize="12"
               Name="SearchQueryBox" />
    </Border>

    <!-- Results panel -->
    <Panel Grid.Row="2">

      <ProgressBar IsIndeterminate="True"
                   IsVisible="{Binding IsLoading}"
                   VerticalAlignment="Top" />

      <!-- Not yet searched -->
      <TextBlock Text="start typing to search your messages"
                 FontSize="12" Foreground="#404040"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsVisible="{Binding !HasSearched}" />

      <!-- No results -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="4"
                  IsVisible="{Binding ShowNoResults}">
        <TextBlock Text="{Binding EmptyStateHeading}"
                   FontSize="13" Foreground="#888888"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding EmptyStateBody}"
                   FontSize="11" Foreground="#555555"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Results list -->
      <ListBox ItemsSource="{Binding SearchResults}"
               IsVisible="{Binding HasSearched}"
               SelectionMode="Single"
               Background="Transparent"
               BorderThickness="0"
               Name="ResultsList">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:SearchResultItemViewModel">
            <Border BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="12,8">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding ChatName}"
                             FontSize="12" FontWeight="Bold"
                             Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                  <TextBlock Text="{Binding Snippet}"
                             FontSize="12" Foreground="#888888"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding Timestamp}"
                           FontSize="11" Foreground="#444444"
                           VerticalAlignment="Top" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

    </Panel>
  </Grid>
</UserControl>
