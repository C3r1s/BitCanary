<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.SearchResultsView"
             x:DataType="vm:SearchViewModel">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">

    <!-- Title -->
    <TextBlock Text="Search Results" FontSize="22" FontWeight="SemiBold" />

    <!-- Search input -->
    <TextBox Grid.Row="1"
             Watermark="Search all conversations..."
             Text="{Binding SearchQuery, Mode=TwoWay}"
             Name="SearchQueryBox" />

    <!-- Results panel: overlapping layers in Row 2 -->
    <Panel Grid.Row="2">

      <!-- Loading indicator -->
      <ProgressBar IsIndeterminate="True"
                   IsVisible="{Binding IsLoading}"
                   VerticalAlignment="Top" />

      <!-- "Start typing" empty state — before any search -->
      <TextBlock Text="Start typing to search your messages."
                 FontSize="16"
                 Opacity="0.7"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsVisible="{Binding !HasSearched}" />

      <!-- No results empty state -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="8"
                  IsVisible="{Binding ShowNoResults}">
        <TextBlock Text="{Binding EmptyStateHeading}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding EmptyStateBody}"
                   FontSize="16"
                   Opacity="0.7"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Results list (ListBox for keyboard navigation) -->
      <ListBox ItemsSource="{Binding SearchResults}"
               IsVisible="{Binding HasSearched}"
               SelectionMode="Single"
               Name="ResultsList">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:SearchResultItemViewModel">
            <Grid ColumnDefinitions="*,Auto" Margin="0,8">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding ChatName}"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Snippet}"
                           FontSize="16"
                           Opacity="0.85"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          Spacing="4">
                <TextBlock Text="{Binding Timestamp}"
                           FontSize="13"
                           Opacity="0.7" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

    </Panel>
  </Grid>
</UserControl>
