<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Messenger.Client.Avalonia.ViewModels"
             x:Class="Messenger.Client.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <Border Classes="surface-card">
    <StackPanel Spacing="16">
      <StackPanel Spacing="4">
        <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="{Binding ConnectionStatus}" Opacity="0.72" TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Theme" FontWeight="SemiBold" />
        <ComboBox ItemsSource="{Binding ThemeOptions}"
                  SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Label}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Command="{Binding SaveThemeCommand}" Content="Apply Theme" />
      </StackPanel>

      <CheckBox Content="Send by Enter" IsChecked="{Binding SendByEnter, Mode=TwoWay}" />
      <CheckBox Content="Compact Mode" IsChecked="{Binding UseCompactMode, Mode=TwoWay}" />
      <CheckBox Content="Custom Emoji Enabled" IsChecked="{Binding EnableCustomEmoji, Mode=TwoWay}" />
    </StackPanel>
  </Border>
</UserControl>
